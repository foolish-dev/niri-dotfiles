#!/usr/bin/env bash
# Re-test the AMD ISP4 / MIPI camera pipeline on the ASUS ROG Flow Z13.
# Reports when cameras become detectable — i.e. when upstream kernel +
# libcamera have caught up to the ov13b10 sensor + AMD ISP4 capture path.
# Driven by webcam-recheck.timer (quarterly). Log-only; no fixes applied.
set -u
set -o pipefail

LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}"
LOG="$LOG_DIR/webcam-recheck.log"
mkdir -p "$LOG_DIR"

{
    printf '\n=== %s ===\n' "$(date -Is)"
    printf 'Kernel:    %s\n' "$(uname -r)"
    printf 'libcamera: %s\n' "$(pacman -Q libcamera 2>/dev/null | awk '{print $2}')"
    printf 'Mesa:      %s\n' "$(pacman -Q mesa 2>/dev/null | awk '{print $2}')"
    printf '\n--- /dev/video* ---\n'
    ls /dev/video* 2>&1 || true
    printf '\n--- /dev/media* ---\n'
    ls /dev/media* 2>&1 || true
    printf '\n--- cam --list ---\n'
    cam --list 2>&1 || true
} >>"$LOG" 2>&1

if compgen -G '/dev/video*' >/dev/null; then
    /usr/bin/notify-send -u normal -i camera-web \
        "Z13 webcam: /dev/video* now present" \
        "Pipeline may be working — re-test. Log: $LOG"
fi

exit 0
