#!/usr/bin/env bash
# =============================================================================
# sddm-theme -- Switch SDDM themes with fzf
# Usage: sddm-theme [theme-name]
# =============================================================================
set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/niri-dotfiles}"
SDDM_THEMES="/usr/share/sddm/themes"
# deploy.sh creates an upgrade-proof local copy of the packaged theme; fall
# back to the upstream dir so `sddm-theme` still works pre-deploy.
ASTRONAUT_LOCAL="$SDDM_THEMES/sddm-astronaut-local"
ASTRONAUT_UPSTREAM="$SDDM_THEMES/sddm-astronaut-theme"
if [[ -d "$ASTRONAUT_LOCAL" ]]; then
  ASTRONAUT_DIR="$ASTRONAUT_LOCAL"
  ASTRONAUT_NAME="sddm-astronaut-local"
else
  ASTRONAUT_DIR="$ASTRONAUT_UPSTREAM"
  ASTRONAUT_NAME="sddm-astronaut-theme"
fi
CUSTOM_THEMES="$DOTFILES/etc/sddm-themes"

RED='\033[0;31m'
GRN='\033[0;32m'
BLU='\033[0;34m'
CYN='\033[0;36m'
YLW='\033[1;33m'
RST='\033[0m'

info()  { echo -e "${BLU}[*]${RST} $*"; }
ok()    { echo -e "${GRN}[+]${RST} $*"; }
warn()  { echo -e "${YLW}[!]${RST} $*"; }
fail()  { echo -e "${RED}[-]${RST} $*"; exit 1; }

# Gather available themes
declare -A THEMES

# Built-in astronaut variants
if [[ -d "$ASTRONAUT_DIR/Themes" ]]; then
  for conf in "$ASTRONAUT_DIR/Themes"/*.conf; do
    name="$(basename "$conf" .conf)"
    THEMES["$name"]="astronaut:$conf"
  done
fi

# Custom Tokyo Night configs
if [[ -d "$CUSTOM_THEMES" ]]; then
  for conf in "$CUSTOM_THEMES"/*.conf; do
    name="$(basename "$conf" .conf)"
    THEMES["$name"]="astronaut:$conf"
  done
fi

# Other installed SDDM themes
for dir in "$SDDM_THEMES"/*/; do
  name="$(basename "$dir")"
  # Skip both the packaged and local astronaut dirs -- their variants are
  # already enumerated from the Themes/*.conf glob above.
  [[ "$name" == "sddm-astronaut-theme" || "$name" == "sddm-astronaut-local" ]] && continue
  [[ -f "$dir/Main.qml" || -f "$dir/theme.conf" ]] && THEMES["$name"]="standalone:$dir"
done

if [[ ${#THEMES[@]} -eq 0 ]]; then
  fail "No SDDM themes found. Run install.sh first."
fi

# Select theme
if [[ $# -ge 1 ]]; then
  SELECTED="$1"
else
  SELECTED=$(printf '%s\n' "${!THEMES[@]}" | sort | fzf --prompt="SDDM Theme> " --height=20 --reverse) || exit 0
fi

[[ -z "$SELECTED" ]] && exit 0
[[ -v "THEMES[$SELECTED]" ]] || fail "Theme '$SELECTED' not found. Available: ${!THEMES[*]}"

IFS=':' read -r TYPE THEME_PATH <<< "${THEMES[$SELECTED]}"

if [[ "$TYPE" == "astronaut" ]]; then
  # Copy wallpaper to astronaut Backgrounds dir
  info "Setting astronaut theme variant: $SELECTED"

  # Copy custom config to astronaut Themes dir
  DEST="$ASTRONAUT_DIR/Themes/$SELECTED.conf"
  if [[ "$THEME_PATH" != "$DEST" && -f "$THEME_PATH" ]]; then
    sudo cp "$THEME_PATH" "$DEST"
    ok "Copied config to $DEST"
  fi

  # Copy a matching wallpaper from dotfiles if available
  WALL_SRC="$DOTFILES/wallpapers"
  if [[ -d "$WALL_SRC" ]]; then
    # Pick the best wallpaper for this theme
    case "$SELECTED" in
      tokyo-night)          WP="samurai.png" ;;
      tokyo-night-cyberpunk) WP="matrix.png" ;;
      *)                    WP="" ;;
    esac
    if [[ -n "$WP" && -f "$WALL_SRC/$WP" ]]; then
      sudo cp "$WALL_SRC/$WP" "$ASTRONAUT_DIR/Backgrounds/tokyonight.png"
      ok "Set background: $WP"
    fi
  fi

  # Point metadata.desktop to the selected config
  sudo sed -i "s|^ConfigFile=.*|ConfigFile=Themes/$SELECTED.conf|" "$ASTRONAUT_DIR/metadata.desktop"
  ok "Updated metadata.desktop -> Themes/$SELECTED.conf"

  # Set SDDM to use the astronaut theme (local copy if deploy.sh has run;
  # otherwise the packaged dir, with the caveat that pacman upgrades will
  # clobber this until ./deploy.sh is run).
  if [[ "$ASTRONAUT_NAME" == "sddm-astronaut-theme" ]]; then
    warn "Using the packaged theme dir -- pacman -Syu will wipe your edits."
    warn "Run ./deploy.sh to create an upgrade-proof local copy."
  fi
  sudo tee /etc/sddm.conf.d/theme.conf > /dev/null <<EOF
[Theme]
Current=$ASTRONAUT_NAME
CursorTheme=Bibata-Modern-Classic
CursorSize=24
EOF

else
  # Standalone theme
  THEME_NAME="$(basename "$THEME_PATH")"
  info "Setting standalone theme: $THEME_NAME"

  sudo tee /etc/sddm.conf.d/theme.conf > /dev/null <<EOF
[Theme]
Current=$THEME_NAME
CursorTheme=Bibata-Modern-Classic
CursorSize=24
EOF
fi

ok "SDDM theme set to: ${CYN}$SELECTED${RST}"
info "Changes take effect on next login screen."
