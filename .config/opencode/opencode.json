{
  "$schema": "https://opencode.ai/config.json",

  // Default to the tools-capable Crow variant so agents work out of the box.
  // Use `--model ollama/deckard-9b` for non-tool chat.
  "model": "ollama/jaahas/crow:9b",

  // ── AI Provider Configuration ────────────────────────────────
  // Ollama is already installed — use locally with Crow models.
  // Model IDs must match `ollama list` output exactly.
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        // Local build (Modelfile uses Qwen-style JSON tool template).
        // Ollama reports capabilities=[completion, tools].
        "crow-9b-heretic-4.6:latest": {
          "name": "Crow",
          "tool_call": true
        },
        // Crow 9B Heretic Q8_0 — Qwen3.5 9B base, 9.5 GB, 262K ctx.
        // Modelfile bakes Qwen-style <tool_call> template so tools work
        // through /v1/chat/completions. Capabilities=[completion, tools, thinking].
        "crow-9b-heretic:q8_0": {
          "name": "Crow 9B Heretic Q8_0 — Tools + thinking (Qwen3.5)",
          "tool_call": true,
          "reasoning": true
        },
        // Same model, smaller quant for faster inference / lower VRAM.
        "crow-9b-heretic:q5_k_m": {
          "name": "Crow 9B Heretic Q5_K_M — Tools + thinking (lighter quant)",
          "tool_call": true,
          "reasoning": true
        },
        // Tuned coder variant: temp 0.3, num_ctx 32768, baked SYSTEM prompt.
        // Built from Modelfile.q8.coder — see ~/models/crow-9b-heretic/.
        "crow-9b-heretic:q8_0-coder": {
          "name": "Crow 9B Heretic Q8_0 Coder — Tuned (32K ctx, low temp)",
          "tool_call": true,
          "reasoning": true
        },
        // Supports tools + thinking — use this for agent workflows.
        "jaahas/crow:9b": {
          "name": "Crow 9B — General coding assistant",
          "tool_call": true
        },
        // Qwen 3.5 9B heretic — pulled from agentajul namespace (17 GB).
        // Ollama manifest declares capabilities=[completion] only; tool
        // requests via /v1/chat/completions are rejected server-side even
        // though the underlying qwen3.5 architecture supports them (verified
        // on LM Studio). Use for non-tool chat, or rebuild via Modelfile
        // with a tools-compatible template to enable agent workflows.
        "agentajul/qwen3.5-heretic-9b:latest": {
          "name": "Qwen 3.5 9B Heretic — Uncensored reasoning (Ollama; non-tool)",
          "tool_call": true,
          "reasoning": true
        },
        // DavidAU's Qwen 3.5 9B Claude-4.6-Opus-Deckard V4.2 thinking variant
        // built locally from GGUF (Q8_0, 10 GB) at ~/models/deckard-9b/.
        // Modelfile uses ChatML template + Deckard system prompt baked in.
        // Same caveat as agentajul: ollama capabilities=[completion]; tool
        // calls via /v1/chat/completions may be rejected server-side.
        "deckard-9b": {
          "name": "Deckard 9B — Qwen3.5 Opus thinking (non-tool; baked system prompt)",
          "tool_call": false,
          "reasoning": true
        },
        // Janus — FoolDev's Qwen 3.6 35B-A3B MoE (3B active, Q4_K_M, 18 GB).
        // Rebuilt locally at ~/models/janus-35b/Modelfile because the upstream
        // hf.co/FoolDev/janus:Q4_K_M ships a broken template (missing user role
        // marker -- `{{ if .Prompt }} .Prompt }}<|im_end|>`) and declares only
        // capabilities=[completion]. Local `janus:latest` adds:
        //   - Proper Qwen3 ChatML template w/ <tool_call> XML format
        //   - Capabilities=[completion, tools, thinking] (verified via curl)
        //   - HF README sampling defaults (temp 0.6, top_p 0.95, top_k 20)
        //   - num_ctx=32768 (Ollama default 4K is useless for agent work)
        //   - Baked Janus system prompt from upstream README
        "janus:latest": {
          "name": "Janus 35B-A3B MoE — Qwen3.6 distilled w/ Opus 4.7 teacher",
          "tool_call": true,
          "reasoning": true
        }
      }
    },

    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        // Same base model as the Ollama Heretic — completion-only.
        "crow-9b-heretic-4.6": {
          "name": "Crow 9B Heretic (LM Studio) — Security-focused coding assistant",
          "tool_call": true
        },
        // Crow 9B Heretic 4.6 — i1 imatrix quant (mradermacher's crownelius repack).
        // Verified tool-calling via LM Studio endpoint.
        "crownelius-crow-9b-heretic-4.6-i1": {
          "name": "Crow 9B Heretic i1 — Security-focused coding (imatrix quant)",
          "tool_call": true
        },
        // Qwen3 14B — official release, verified tool-calling + reasoning via LM Studio.
        "qwen/qwen3-14b": {
          "name": "Qwen3 14B — Reasoning + tool calling",
          "tool_call": true,
          "reasoning": true
        }
      }
    }

    // Alternative: Claude for heavier tasks when needed (requires API key):
    /*
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Claude (remote)",
      "options": { "apiKey": "{env:ANTHROPIC_API_KEY}" },
      "models": {
        "claude-opus-4-7":         { "name": "Claude Opus 4.7" },
        "claude-sonnet-4-6":       { "name": "Claude Sonnet 4.6" },
        "claude-haiku-4-5-20251001": { "name": "Claude Haiku 4.5" }
      }
    }
    */

    // Alternative: Google for cheaper inference (requires API key):
    /*
    "google": {
      "npm": "@ai-sdk/google",
      "name": "Google (remote)",
      "options": { "apiKey": "{env:GOOGLE_API_KEY}" },
      "models": {
        "gemini-2.0-flash": { "name": "Gemini 2.0 Flash" },
        "gemini-1.5-pro":   { "name": "Gemini 1.5 Pro" }
      }
    }
    */
  },

  // ── MCP Server Configuration ─────────────────────────────────
  // Servers referenced by agents below. Defining them here makes
  // `context7` / `hexstrike-ai` resolvable as tool names.
  "mcp": {
    "context7": {
      "type": "remote",
      // /sse was retired -- current endpoint is streamable HTTP at /mcp.
      // Add CONTEXT7_API_KEY to headers (via {env:CONTEXT7_API_KEY}) for
      // higher rate limits; anonymous access still works.
      "url": "https://mcp.context7.com/mcp"
    },
    "hexstrike-ai": {
      "type": "local",
      "command": ["hexstrike-mcp"],
      "enabled": true,
      "timeout": 30000
    },
    // From heimdall_opencode — demo MCP, runs via `opencode x`.
    "weather": {
      "type": "local",
      "command": ["opencode", "x", "@h1deya/mcp-server-weather"]
    }
  },

  // ── Agent Configuration ──────────────────────────────────────
  // Agent keys are the identifier used after `@` in chat (e.g. `@build`).
  // Don't prefix keys with `@` — opencode adds it when you invoke.
  "agent": {
    // Security research — requires hexstrike_server.py running at 127.0.0.1:8888.
    // Commands surfaced (documentation):
    //   /hexstrike analyze TARGET      — comprehensive security analysis
    //   /hexstrike nmap -t TARGET_IP   — full Nmap service detection
    //   /hexstrike rustscan -r TARGET  — fast port enumeration
    //   /hexstrike nikto -h URL        — web vuln assessment
    //   /hexstrike nuclei -u URL       — CVE-based scanning
    //   /hexstrike sqlmap -u URL       — SQL injection testing
    //   /hexstrike ffuf / gobuster / dirsearch — fuzzing & discovery
    //   /hexstrike wafw00f TARGET      — WAF fingerprinting
    "hexstrike-analyst-context7": {
      "description": "Security research assistant with HexStrike tools + Context7 library analysis for CVE references and dependency scanning",
      "mode": "primary",
      "prompt": "You have access to 150+ security tools via the HexStrike AI server at http://127.0.0.1:8888.\nAlways verify authorization before running any scan or exploit against a target.\nUse this agent for CTF challenges, authorized pentesting engagements, and educational exercises only.\nYou also have access to Context7 MCP for library documentation search — use it when encountering unfamiliar dependencies in security codebases.",
      "tools": {
        "hexstrike-ai": true,
        "context7": true
      }
    },

    // Commands surfaced (documentation):
    //   /sc:pm         — project management session
    //   /sc:research   — deep research with Context7
    //   /sc:implement  — implementation assistance
    //   /sc:code-review
    "superclaude-architect-context7": {
      "description": "Codebase architect enhanced with Context7 library research — for understanding unfamiliar dependencies in large projects",
      "mode": "primary",
      "prompt": "You have systematic access to read/edit files across the entire codebase.\nUse multi-step reasoning to understand architecture before suggesting changes.\nLeverage Mermaid/Krux for diagrams when explaining complex systems.",
      "tools": {
        "context7": true
      }
    },

    // Migrated from the deprecated top-level `mode` block.
    // `tools` keyed by MCP server name gates access; `true` = allow.
    "build": {
      "description": "Specializes in understanding build systems, CI/CD pipelines, and infrastructure code",
      "mode": "primary",
      "tools": {
        "hexstrike-ai": true,
        "context7": true
      }
    },

    "analyze": {
      "description": "Security-focused analysis of codebases for vulnerabilities and security issues",
      "mode": "primary",
      "tools": {
        "hexstrike-ai": true,
        "context7": true
      }
    }
  }
}
