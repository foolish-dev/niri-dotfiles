# Secrets / credentials
.env
.env.*
*.pem
*.key
credentials.*
secrets.*

# Per-machine git identity (generated by deploy.sh, deliberately local)
.gitconfig.local

# Editor state
.config/nvim/plugin/
.config/nvim/.luarc.json

# Shell state
.zsh_history
.zcompdump*
.zinit/

# Cache / runtime
.cache/
.local/state/
.config/systemd/user/*.wants/
# systemd-generated Alias= symlinks (e.g. wireplumber → pipewire-session-manager)
.config/systemd/user/pipewire-session-manager.service
# Per-machine, hardware-specific user systemd units. The repo is hardware
# neutral, but ~/.config/systemd/user/ is a symlink into this dir, so any
# machine-specific units a user drops in get gitignored rather than tracked.
.config/systemd/user/z13-*.service
.config/systemd/user/gz302-*.service
*.log
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

# Backups created by deploy.sh
.dotfiles-backup/
backups/
